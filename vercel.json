{
    "framework": "vite",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "trailingSlash": false,
    "cleanUrls": true,
    "routes": [
        {
            "src": "/report.aspx",
            "dest": "/index.html"
        },
        {
            "src": "/receipt/(.*)",
            "dest": "/index.html"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}